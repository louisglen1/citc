{
    "name": "@louisglen1/citc",
    "version": "1.0.0",
    "description": "Client Input Telemetry Collection - A privacy-first browser telemetry SDK for collecting user interaction events with zero dependencies",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc",
        "watch": "tsc --watch",
        "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
        "prepublishOnly": "npm run clean && npm run build",
        "dev": "tsc && npx serve .",
        "demo": "tsc && npx serve . -p 3000",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage"
    },
    "keywords": [
        "telemetry",
        "analytics",
        "browser",
        "input",
        "tracking",
        "privacy",
        "privacy-first",
        "gdpr",
        "user-behavior",
        "event-collection",
        "interaction-tracking",
        "zero-dependencies",
        "typescript"
    ],
    "author": "Louis Glen",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/louisglen/citc.git"
    },
    "bugs": {
        "url": "https://github.com/louisglen/citc/issues"
    },
    "homepage": "https://github.com/louisglen/citc#readme",
    "engines": {
        "node": ">=16.0.0"
    },
    "sideEffects": false,
    "devDependencies": {
        "@vitest/coverage-v8": "^4.0.18",
        "jsdom": "^28.0.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    }
}
