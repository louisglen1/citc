{
    "name": "citc",
    "version": "0.1.0",
    "description": "Client Input Telemetry Collection - A privacy-first browser telemetry SDK",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsc",
        "watch": "tsc --watch",
        "clean": "rm -rf dist"
    },
    "keywords": [
        "telemetry",
        "analytics",
        "browser",
        "input",
        "tracking",
        "privacy"
    ],
